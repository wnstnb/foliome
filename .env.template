# =============================================================================
# Foliome Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=                  # From @BotFather on Telegram
TELEGRAM_CHAT_ID=                    # Your numeric user ID (use @userinfobot to find it)
# DASHBOARD_BOT_TOKEN=              # Only needed if the bot sending the web_app button differs from TELEGRAM_BOT_TOKEN

# --- API Connectors ---
#
# Some institutions offer REST APIs as an alternative to browser automation.
# If your bank has a developer portal or API access, you can build an API
# connector (see connectors/ for examples) and add its credentials here.
#
# Naming convention: <INSTITUTION>_API_KEY (and _SECRET if OAuth)
#
# Examples:
#   MERCURY_API_KEY=               # Mercury dashboard → Settings → API
#   SCHWAB_API_KEY=                # Schwab developer portal → App Details

BANK_API_KEY=

# --- Bank Credentials (Browser Readers) ---
#
# Naming convention: <SLUG>_USERNAME and <SLUG>_PASSWORD
# Slug is the institution name uppercased with hyphens removed.
#
# The institution name must match the usernameEnv/passwordEnv fields in the
# institution config at readers/institutions/<bank>.js. When adding a new bank
# via /learn-institution, the agent will tell you what env var names to use.
#
# Examples:
#   CHASE_USERNAME / CHASE_PASSWORD
#   CAPITALONE_USERNAME / CAPITALONE_PASSWORD
#   APPLECARD_USERNAME / APPLECARD_PASSWORD
#
BANK_USERNAME=
BANK_PASSWORD=

# --- Real Estate ---
HOME_RESIDENCE_ADDRESS=              # Full address for property value tracking (e.g., "123 Main St, City, ST 12345")

# --- Gmail API (for email MFA auto-retrieval) ---
# credentials.json and gmail-token.json are separate files, not env vars.
# See scripts/gmail-mfa.js for setup instructions.
